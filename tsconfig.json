{
    "compilerOptions":  {
                            "target":  "ES2022",
                            "module":  "NodeNext",
                            "moduleResolution":  "NodeNext",
                            "lib":  [
                                        "ES2022",
                                        "DOM"
                                    ],
                            "types":  [
                                          "node"
                                      ],
                            "strict":  false,
                            "declaration":  true,
                            "sourceMap":  true,
                            "outDir":  "dist",
                            "rootDir":  ".",
                            "skipLibCheck":  true,
                            "esModuleInterop":  true,
                            "forceConsistentCasingInFileNames":  true
                        },
    "include":  [
                    "extensions/**/*.ts",
                    "types/**/*.d.ts"
                ],
    "exclude":  [
                    "dist",
                    "node_modules"
                ]
}
